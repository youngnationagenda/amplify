    "@types/node": "^22.19.17",
    "chai": "^6.2.2",
    "ethers": "^6.16.0",
    "hardhat": "^3.9.0",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^3.4.0",
