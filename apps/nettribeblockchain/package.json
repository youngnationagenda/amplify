  "main": "index.js",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:factory": "node scripts/deploy-factory.mjs",
    "deploy:all": "bash scripts/deploy-all.sh",
    "deploy:periphery": "hardhat run --no-compile scripts/deploy-periphery.js --network celoSepolia",
    "deploy:nfpm": "hardhat run --no-compile scripts/deploy-nfpm.js --network celoSepolia",
    "deploy:router": "hardhat run --no-compile scripts/deploy-router.js --network celoSepolia",
    "deploy:quoter": "hardhat run --no-compile scripts/deploy-quoter-v2.js --network celoSepolia",
    "verify": "node scripts/verify.js",
    "pool:create": "hardhat run --no-compile scripts/create-pool.js --network celoSepolia",
    "pool:add": "hardhat run --no-compile scripts/mint-liquidity.js --network celoSepolia",
    "pool:remove": "hardhat run --no-compile scripts/remove-liquidity.js --network celoSepolia",
    "quote": "hardhat run --no-compile scripts/quoter.js --network celoSepolia",
    "swap": "hardhat run --no-compile scripts/router.js --network celoSepolia"
  },
