# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
terraform.tfvars
.terraform.lock.hcl

# Environment-specific variable files (contain secrets)
# Keep .example files tracked as templates
environments/*.tfvars
!environments/*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
