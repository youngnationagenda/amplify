{
  "name": "nettribe-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/nettribexyz",
    "apps/evtelemetryai"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "npm run dev --workspace=apps/nettribexyz",
    "dev:telemetry": "npm run dev --workspace=apps/evtelemetryai",
    "build": "npm run build --workspace=apps/nettribexyz",
    "build:telemetry": "npm run build --workspace=apps/evtelemetryai",
    "build:contracts": "cd apps/nettribeblockchain && pnpm run compile",
    "build:all": "npm run build && npm run build:telemetry && npm run build:contracts",
    "lint": "eslint .",
    "lint:all": "npm run lint --workspaces --if-present && eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:nettribexyz": "vitest --run --project apps/nettribexyz",
    "test:telemetry": "vitest --run --project apps/evtelemetryai"
  },
